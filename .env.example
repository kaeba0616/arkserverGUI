# Server Identity
SESSION_NAME=HidiARK
SERVER_MAP=TheIsland
SERVER_PASSWORD=your_server_password
ADMIN_PASSWORD=your_admin_password
MAX_PLAYERS=20

# Behavior
UPDATE_ON_START=true
BACKUP_ON_STOP=true
WARN_ON_STOP=true

# Steam Workshop Mods (comma-separated Workshop IDs)
# Examples: 731604991 (Structures Plus), 889745138 (Awesome Spyglass)
ARK_MODS=
GAME_MOD_IDS=

# RCON
RCON_HOST=127.0.0.1
RCON_PORT=27020
RCON_PASSWORD=your_admin_password

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_COUNT_MAX=20

# Dashboard
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
DASHBOARD_PASSWORD_HASH=
